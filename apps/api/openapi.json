{
  "components": {
    "schemas": {
      "CancellationAcceptedResponse": {
        "additionalProperties": false,
        "description": "Accepted or idempotently replayed task cancellation receipt.",
        "properties": {
          "duplicate": {
            "title": "Duplicate",
            "type": "boolean"
          },
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "status": {
            "const": "cancelled",
            "default": "cancelled",
            "title": "Status",
            "type": "string"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId",
          "duplicate"
        ],
        "title": "CancellationAcceptedResponse",
        "type": "object"
      },
      "CapabilityResponse": {
        "additionalProperties": false,
        "description": "One fixture capability response.",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "state": {
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "name",
          "state"
        ],
        "title": "CapabilityResponse",
        "type": "object"
      },
      "DecisionAcceptedResponse": {
        "additionalProperties": false,
        "description": "Accepted or idempotently replayed decision receipt.",
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/DecisionValue"
          },
          "duplicate": {
            "title": "Duplicate",
            "type": "boolean"
          },
          "interruptId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Interruptid",
            "type": "string"
          },
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "status": {
            "const": "accepted",
            "default": "accepted",
            "title": "Status",
            "type": "string"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId",
          "interruptId",
          "decision",
          "duplicate"
        ],
        "title": "DecisionAcceptedResponse",
        "type": "object"
      },
      "DecisionRequest": {
        "additionalProperties": false,
        "description": "One complete decision for the exact pending interrupt.",
        "properties": {
          "comment": {
            "anyOf": [
              {
                "maxLength": 1000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Comment"
          },
          "decision": {
            "$ref": "#/components/schemas/DecisionValue"
          },
          "interruptId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Interruptid",
            "type": "string"
          }
        },
        "required": [
          "interruptId",
          "decision"
        ],
        "title": "DecisionRequest",
        "type": "object"
      },
      "DecisionValue": {
        "description": "Supported decisions for the bounded approval interrupt.",
        "enum": [
          "approve",
          "reject",
          "respond"
        ],
        "title": "DecisionValue",
        "type": "string"
      },
      "DemoStatusResponse": {
        "additionalProperties": false,
        "description": "Fixture-only demo status response.",
        "properties": {
          "capabilities": {
            "items": {
              "$ref": "#/components/schemas/CapabilityResponse"
            },
            "title": "Capabilities",
            "type": "array"
          },
          "evidence_class": {
            "$ref": "#/components/schemas/EvidenceClass"
          },
          "mode": {
            "$ref": "#/components/schemas/EvidenceClass"
          },
          "safe_reason": {
            "title": "Safe Reason",
            "type": "string"
          }
        },
        "required": [
          "mode",
          "evidence_class",
          "capabilities",
          "safe_reason"
        ],
        "title": "DemoStatusResponse",
        "type": "object"
      },
      "EvidenceClass": {
        "description": "Origin of an observed capability or status.",
        "enum": [
          "fixture",
          "local-source"
        ],
        "title": "EvidenceClass",
        "type": "string"
      },
      "EvidenceKind": {
        "description": "Bounded evidence kind for the credential-free local runner.",
        "enum": [
          "fixture"
        ],
        "title": "EvidenceKind",
        "type": "string"
      },
      "EvidenceResponse": {
        "additionalProperties": false,
        "description": "Inspectable source-qualified evidence.",
        "properties": {
          "evidenceId": {
            "pattern": "^evidence_[0-9]{8}(?:_[0-9]{2})?$",
            "title": "Evidenceid",
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/EvidenceKind"
          },
          "source": {
            "$ref": "#/components/schemas/EvidenceSource"
          },
          "summary": {
            "maxLength": 300,
            "minLength": 1,
            "title": "Summary",
            "type": "string"
          },
          "verified": {
            "title": "Verified",
            "type": "boolean"
          }
        },
        "required": [
          "evidenceId",
          "kind",
          "summary",
          "source",
          "verified"
        ],
        "title": "EvidenceResponse",
        "type": "object"
      },
      "EvidenceSource": {
        "description": "Truthful provenance for locally generated evidence.",
        "enum": [
          "deterministic-local-runner",
          "reviewer-response"
        ],
        "title": "EvidenceSource",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "additionalProperties": false,
        "description": "Process liveness response, not dependency readiness.",
        "properties": {
          "dependencies_checked": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Dependencies Checked",
            "type": "array"
          },
          "evidence_class": {
            "$ref": "#/components/schemas/EvidenceClass"
          },
          "scope": {
            "default": "process",
            "title": "Scope",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ProcessState"
          }
        },
        "required": [
          "status",
          "evidence_class"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "PendingInterruptResponse": {
        "additionalProperties": false,
        "description": "One actionable local approval interrupt.",
        "properties": {
          "decisions": {
            "default": [
              "approve",
              "reject",
              "respond"
            ],
            "items": {
              "$ref": "#/components/schemas/DecisionValue"
            },
            "title": "Decisions",
            "type": "array"
          },
          "interruptId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Interruptid",
            "type": "string"
          },
          "planRevision": {
            "maximum": 2147483647.0,
            "minimum": 1.0,
            "title": "Planrevision",
            "type": "integer"
          }
        },
        "required": [
          "interruptId",
          "planRevision"
        ],
        "title": "PendingInterruptResponse",
        "type": "object"
      },
      "PlanUpdateRequest": {
        "additionalProperties": false,
        "description": "Edit the exact pending plan revision without silently truncating it.",
        "properties": {
          "expectedRevision": {
            "maximum": 2147483647.0,
            "minimum": 1.0,
            "title": "Expectedrevision",
            "type": "integer"
          },
          "interruptId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Interruptid",
            "type": "string"
          },
          "steps": {
            "items": {
              "type": "string"
            },
            "maxItems": 8,
            "minItems": 1,
            "title": "Steps",
            "type": "array"
          }
        },
        "required": [
          "interruptId",
          "expectedRevision",
          "steps"
        ],
        "title": "PlanUpdateRequest",
        "type": "object"
      },
      "PlanUpdateResponse": {
        "additionalProperties": false,
        "description": "Accepted plan edit receipt.",
        "properties": {
          "interruptId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Interruptid",
            "type": "string"
          },
          "plan": {
            "$ref": "#/components/schemas/ProposedPlanResponse"
          },
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId",
          "interruptId",
          "plan"
        ],
        "title": "PlanUpdateResponse",
        "type": "object"
      },
      "ProcessState": {
        "description": "Process-only liveness state.",
        "enum": [
          "alive"
        ],
        "title": "ProcessState",
        "type": "string"
      },
      "ProposedPlanResponse": {
        "additionalProperties": false,
        "description": "Current plan available for inspection and pre-execution editing.",
        "properties": {
          "evidenceRefs": {
            "items": {
              "pattern": "^evidence_[0-9]{8}(?:_[0-9]{2})?$",
              "type": "string"
            },
            "title": "Evidencerefs",
            "type": "array"
          },
          "revision": {
            "maximum": 2147483647.0,
            "minimum": 1.0,
            "title": "Revision",
            "type": "integer"
          },
          "steps": {
            "items": {
              "type": "string"
            },
            "maxItems": 8,
            "minItems": 1,
            "title": "Steps",
            "type": "array"
          },
          "title": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "revision",
          "title",
          "steps",
          "evidenceRefs"
        ],
        "title": "ProposedPlanResponse",
        "type": "object"
      },
      "TaskAcceptedResponse": {
        "additionalProperties": false,
        "description": "Queued task receipt returned before background work starts.",
        "properties": {
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "status": {
            "const": "queued",
            "default": "queued",
            "title": "Status",
            "type": "string"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId"
        ],
        "title": "TaskAcceptedResponse",
        "type": "object"
      },
      "TaskCreateRequest": {
        "additionalProperties": false,
        "description": "Bounded local task creation request.",
        "properties": {
          "prompt": {
            "maxLength": 8000,
            "minLength": 1,
            "title": "Prompt",
            "type": "string"
          }
        },
        "required": [
          "prompt"
        ],
        "title": "TaskCreateRequest",
        "type": "object"
      },
      "TaskDetailResponse": {
        "additionalProperties": false,
        "description": "Task summary plus the currently actionable interrupt.",
        "properties": {
          "evidence": {
            "items": {
              "$ref": "#/components/schemas/EvidenceResponse"
            },
            "title": "Evidence",
            "type": "array"
          },
          "lastEventId": {
            "minimum": 1.0,
            "title": "Lasteventid",
            "type": "integer"
          },
          "objective": {
            "maxLength": 8000,
            "minLength": 1,
            "title": "Objective",
            "type": "string"
          },
          "pendingInterrupt": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PendingInterruptResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "proposedPlan": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ProposedPlanResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "result": {
            "anyOf": [
              {
                "maxLength": 18048,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          },
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/TaskWireStatus"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          },
          "title": {
            "maxLength": 80,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId",
          "title",
          "objective",
          "status",
          "lastEventId",
          "pendingInterrupt",
          "proposedPlan",
          "evidence"
        ],
        "title": "TaskDetailResponse",
        "type": "object"
      },
      "TaskListResponse": {
        "additionalProperties": false,
        "description": "Deterministically ordered task collection.",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/TaskSummaryResponse"
            },
            "title": "Items",
            "type": "array"
          }
        },
        "required": [
          "items"
        ],
        "title": "TaskListResponse",
        "type": "object"
      },
      "TaskResultResponse": {
        "additionalProperties": false,
        "description": "Completed prompt-specific local result.",
        "properties": {
          "result": {
            "maxLength": 18048,
            "minLength": 1,
            "title": "Result",
            "type": "string"
          },
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "status": {
            "const": "completed",
            "title": "Status",
            "type": "string"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId",
          "status",
          "result"
        ],
        "title": "TaskResultResponse",
        "type": "object"
      },
      "TaskSummaryResponse": {
        "additionalProperties": false,
        "description": "Safe task summary containing only the sanitized objective.",
        "properties": {
          "lastEventId": {
            "minimum": 1.0,
            "title": "Lasteventid",
            "type": "integer"
          },
          "objective": {
            "maxLength": 8000,
            "minLength": 1,
            "title": "Objective",
            "type": "string"
          },
          "runId": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
            "title": "Runid",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/TaskWireStatus"
          },
          "taskId": {
            "pattern": "^task_[0-9]{8}$",
            "title": "Taskid",
            "type": "string"
          },
          "title": {
            "maxLength": 80,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "runId",
          "title",
          "objective",
          "status",
          "lastEventId"
        ],
        "title": "TaskSummaryResponse",
        "type": "object"
      },
      "TaskWireStatus": {
        "enum": [
          "queued",
          "running",
          "waiting-approval",
          "completed",
          "rejected",
          "failed",
          "cancelled"
        ],
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Credential-free local task and fixture behavior; no live provider contract.",
    "title": "Deep Work API fixture scaffold",
    "version": "0.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/demo/status": {
      "get": {
        "description": "Return deterministic fixture-only capability status.",
        "operationId": "demo_status_api_v1_demo_status_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DemoStatusResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Demo Status"
      }
    },
    "/api/v1/tasks": {
      "get": {
        "operationId": "list_tasks_api_v1_tasks_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskListResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Tasks",
        "tags": [
          "tasks"
        ]
      },
      "post": {
        "operationId": "create_task_api_v1_tasks_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskAcceptedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Task",
        "tags": [
          "tasks"
        ]
      }
    },
    "/api/v1/tasks/{task_id}": {
      "get": {
        "operationId": "get_task_api_v1_tasks__task_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "pattern": "^task_[0-9]{8}$",
              "title": "Task Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDetailResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Task",
        "tags": [
          "tasks"
        ]
      }
    },
    "/api/v1/tasks/{task_id}/cancel": {
      "post": {
        "operationId": "cancel_task_api_v1_tasks__task_id__cancel_post",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "pattern": "^task_[0-9]{8}$",
              "title": "Task Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancellationAcceptedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Cancel Task",
        "tags": [
          "tasks"
        ]
      }
    },
    "/api/v1/tasks/{task_id}/decisions": {
      "post": {
        "operationId": "record_decision_api_v1_tasks__task_id__decisions_post",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "pattern": "^task_[0-9]{8}$",
              "title": "Task Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DecisionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionAcceptedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Record Decision",
        "tags": [
          "tasks"
        ]
      }
    },
    "/api/v1/tasks/{task_id}/events": {
      "get": {
        "operationId": "task_events_api_v1_tasks__task_id__events_get",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "pattern": "^task_[0-9]{8}$",
              "title": "Task Id",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Last-Event-ID",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Last-Event-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Task Events",
        "tags": [
          "tasks"
        ]
      }
    },
