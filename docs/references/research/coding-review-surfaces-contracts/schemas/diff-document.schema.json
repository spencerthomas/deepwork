{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProbeDiffDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["repository_binding", "base_sha", "head_sha", "patch_sha256", "files", "document_sha256"],
  "properties": {
    "repository_binding": {"type": "string", "minLength": 1},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "patch_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status", "binary", "hunks"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "previous_path": {"type": ["string", "null"]},
          "status": {"enum": ["added", "modified", "deleted", "renamed", "copied", "type-change", "submodule"]},
          "binary": {"type": "boolean"},
          "hunks": {"type": "array"}
        }
      }
    },
    "document_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
