{
  "$id": "https://schemas.example.invalid/deepwork/rubric.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "criteria": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "criterion_id": {
            "minLength": 1,
            "type": "string"
          },
          "evidence_refs": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "order": {
            "minimum": 0,
            "type": "integer"
          },
          "semantics": {
            "enum": [
              "required",
              "advisory"
            ]
          },
          "state": {
            "enum": [
              "pass",
              "fail",
              "uncertain",
              "not_evaluated"
            ]
          }
        },
        "required": [
          "criterion_id",
          "order",
          "semantics",
          "state",
          "evidence_refs"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "identity": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "type": "string"
        },
        "attempt_id": {
          "minLength": 1,
          "type": "string"
        },
        "run_id": {
          "minLength": 1,
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "type": "string"
        },
        "task_id": {
          "minLength": 1,
          "type": "string"
        },
        "tenant_id": {
          "minLength": 1,
          "type": "string"
        },
        "workspace_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "tenant_id",
        "workspace_id",
        "source_id",
        "actor_id",
        "task_id",
        "run_id",
        "attempt_id"
      ],
      "type": "object"
    },
    "rubric_id": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "dw.rubric.v1"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "identity",
    "rubric_id",
    "version",
    "criteria"
  ],
  "title": "rubric",
  "type": "object"
}
