{
  "schemaDialect": "json-schema-2020-12",
  "$id": "urn:deep-work:fixture:product-demo:capability-manifest:1",
  "title": "Private product-demo capability evidence",
  "description": "Fixture evidence cannot establish a live runtime capability.",
  "type": "object",
  "required": ["formatVersion", "manifestId", "synthetic", "runtimeKind", "capabilities"],
  "properties": {
    "formatVersion": {"const": "1.0.0"},
    "manifestId": {"type": "string", "pattern": "^fx_manifest_[a-z0-9_]+$"},
    "synthetic": {"const": true},
    "runtimeKind": {"enum": ["fixture", "classic", "mda", "fleet", "local"]},
    "capabilities": {"type": "array"}
  },
  "additionalProperties": false
}
