{
  "name": "deepwork",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "make build",
    "build:ts": "turbo run build",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "check": "make check",
    "check:ts": "turbo run format-check lint typecheck test build",
    "check-architecture": "make check-architecture",
    "check-architecture:ts": "python3 tools/architecture/check.py --root . --graph tools/architecture/graph.json --fixtures internal/fixtures/architecture --verify-negative && turbo run check-architecture",
    "ci": "make ci",
    "contract": "make contract",
    "contract:ts": "turbo run contract",
    "dev": "./dev",
    "demo:web": "NEXT_PUBLIC_DEMO_MODE=fixture pnpm --filter @deepwork/web dev",
    "dev:web": "pnpm --filter @deepwork/web dev",
    "format": "make format",
    "format:ts": "turbo run format",
    "format-check": "make format-check",
    "format-check:ts": "turbo run format-check",
    "lint": "make lint",
    "lint:ts": "turbo run lint",
    "package-check": "make package-check",
    "package-check:ts": "turbo run package-check",
    "test": "make test",
    "test:ts": "turbo run test",
    "typecheck": "make typecheck",
    "typecheck:ts": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "turbo": "2.10.6",
    "typescript": "7.0.2"
  }
}
