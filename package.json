{
  "name": "deepwork",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm check-architecture && turbo run format-check lint typecheck test build",
    "check-architecture": "python3 tools/architecture/check.py --root . --graph tools/architecture/graph.json --fixtures internal/fixtures/architecture --verify-negative && turbo run check-architecture",
    "contract": "turbo run contract",
    "dev": "./dev",
    "demo:web": "NEXT_PUBLIC_DEMO_MODE=fixture pnpm --filter @deepwork/web dev",
    "dev:web": "pnpm --filter @deepwork/web dev",
    "format": "turbo run format",
    "format-check": "turbo run format-check",
    "lint": "turbo run lint",
    "package-check": "turbo run package-check",
    "test": "turbo run test",
    "test:e2e-demo": "playwright test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.61.1",
    "axe-core": "4.11.0",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "turbo": "2.10.6",
    "typescript": "7.0.2"
  }
}
